# Cloudflare Workers Static Assets headers.
# Docs: https://developers.cloudflare.com/workers/static-assets/headers/
#
# Strategy:
#   - NO COOP/COEP — Room 3.0 OPFS uses OpfsSAHPoolDb (SAH Pool VFS) which
#     does not require SharedArrayBuffer. Firebase Auth signInWithPopup and
#     third-party scripts (Stripe, analytics) work without restrictions.
#   - Hashed assets (wasm, chunk JS) → 1 year, immutable.
#   - Entry points (index.html, composeApp.js, init.js) → always revalidate.
#   - Compose resources (fixed names) → 1 day with revalidation.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

/*.wasm
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/wasm

/composeApp.*.js
  Cache-Control: public, max-age=31536000, immutable

/index.html
  Cache-Control: public, max-age=0, must-revalidate

/composeApp.js
  Cache-Control: public, max-age=0, must-revalidate

/init.js
  Cache-Control: public, max-age=0, must-revalidate

/composeResources/*
  Cache-Control: public, max-age=86400, must-revalidate
