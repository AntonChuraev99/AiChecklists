# Cloudflare Workers Static Assets headers.
# Docs: https://developers.cloudflare.com/workers/static-assets/headers/
#
# Strategy:
#   - Cross-origin isolation (REQUIRED for Room 3.0 OPFS + SharedArrayBuffer).
#   - Hashed assets (wasm, chunk JS) → 1 year, immutable.
#   - Entry points (index.html, composeApp.js, init.js) → always revalidate.
#   - Compose resources (fixed names) → 1 day with revalidation.

/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Cross-Origin-Resource-Policy: cross-origin
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

/*.wasm
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/wasm

/composeApp.*.js
  Cache-Control: public, max-age=31536000, immutable

/index.html
  Cache-Control: public, max-age=0, must-revalidate

/composeApp.js
  Cache-Control: public, max-age=0, must-revalidate

/init.js
  Cache-Control: public, max-age=0, must-revalidate

/composeResources/*
  Cache-Control: public, max-age=86400, must-revalidate
