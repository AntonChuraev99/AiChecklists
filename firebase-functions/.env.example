# Firebase Cloud Functions Environment Variables
# DO NOT COMMIT: Use this as template, never store actual secrets in .env file
#
# For deployment:
# 1. Set environment variables before running deploy.sh:
#    export GEMINI_API_KEY="your_actual_key"
#    ./deploy.sh
#
# 2. Or use Google Cloud Secret Manager (recommended for production):
#    gcloud secrets create gemini-api-key --data-file=-
#    gcloud functions deploy analyze_and_fill_checklist --set-secrets="GEMINI_API_KEY=gemini-api-key:latest"

# Google Cloud Project Configuration
PROJECT_ID=aichecklists-40230
REGION=us-central1

# Gemini API Key
# Generate from: https://aistudio.google.com/app/apikey
# SECURITY: This should NOT be committed. Use environment variables or Google Cloud Secrets.
GEMINI_API_KEY=your_key_here

# Firebase Admin SDK Service Account
# Download from: Firebase Console > Project Settings > Service Accounts > Generate new private key
# SECURITY: Never commit service account JSON. Store in Google Cloud Secret Manager.
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account-key.json

# Optional: Runtime configuration
LOG_LEVEL=INFO
TIMEOUT_SECONDS=60
MEMORY_MB=512
