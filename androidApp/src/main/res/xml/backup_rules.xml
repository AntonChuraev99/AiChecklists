<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ (API 31+) backup rules -->
<!-- DataStore file lives at files/user/datastore.preferences_pb -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="user/"/>
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="user/"/>
    </device-transfer>
</data-extraction-rules>
