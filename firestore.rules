rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User-scoped data: only owner can read/write.
    // READ also permits the owner's linked CREDIT doc, whose document id is the
    // device-registration UUID (NOT the Firebase Auth uid) but carries
    // google_uid == the owner's uid. Needed for the client-side real-time credit
    // listener (UserCreditsSync) — without it the balance can't sync across devices.
    // WRITE stays strict: the credit doc is written only server-side by Cloud
    // Functions (Admin SDK), never by the client.
    match /users/{userId} {
      allow read: if request.auth != null
                  && (request.auth.uid == userId
                      || (resource != null && resource.data.google_uid == request.auth.uid));
      allow write: if request.auth != null && request.auth.uid == userId;

      match /checklists/{checklistId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Existing collections used by Cloud Functions (server-side access via Admin SDK)
    // usage, credits_restore_log, credits_refill_log, premium_events_log,
    // rc_customers, rc_events — accessed only by Admin SDK, default deny is correct.
  }
}
